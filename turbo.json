{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "BABBLEDECK_RELEASE_COMMIT",
    "BABBLEDECK_RELEASE_BRANCH",
    "BABBLEDECK_RELEASE_BUILT_AT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "outputs": []
    },
    "test": {
      "outputs": ["coverage/**"]
    }
  }
}
