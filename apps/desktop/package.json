{
  "name": "@babbledeck/desktop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "check": "tsx ../../scripts/verify-wrapper-configs.ts --desktop",
    "build": "pnpm check",
    "lint": "pnpm check",
    "typecheck": "pnpm check",
    "test": "pnpm check",
    "native:check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "native:dev": "tauri dev",
    "native:build": "tauri build",
    "native:smoke:headless": "bash -lc 'timeout 15s env WEBKIT_DISABLE_COMPOSITING_MODE=1 GDK_BACKEND=x11 NO_AT_BRIDGE=1 xvfb-run -a src-tauri/target/release/babbledeck-desktop; status=$?; if [ \"$status\" -eq 124 ]; then exit 0; fi; exit \"$status\"'",
    "native:info": "tauri info"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "tsx": "latest"
  }
}
