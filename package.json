{
  "name": "babbledeck",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "e2e": "env -u NO_COLOR playwright test",
    "e2e:headed": "env -u NO_COLOR playwright test --headed",
    "deploy:production": "scripts/deploy-production.sh",
    "audio:cutover:production": "scripts/cutover-audio-storage.sh",
    "db:validate": "DATABASE_URL=${DATABASE_URL:-postgresql://babbledeck:babbledeck@localhost:55432/babbledeck_dev} prisma validate --schema db/schema.prisma",
    "db:generate": "DATABASE_URL=${DATABASE_URL:-postgresql://babbledeck:babbledeck@localhost:55432/babbledeck_dev} prisma generate --schema db/schema.prisma",
    "db:migrate": "DATABASE_URL=${DATABASE_URL:-postgresql://babbledeck:babbledeck@localhost:55432/babbledeck_dev} prisma migrate deploy --schema db/schema.prisma",
    "db:migrate:dev": "DATABASE_URL=${DATABASE_URL:-postgresql://babbledeck:babbledeck@localhost:55432/babbledeck_dev} prisma migrate dev --schema db/schema.prisma",
    "db:seed": "pnpm db:generate && DATABASE_URL=${DATABASE_URL:-postgresql://babbledeck:babbledeck@localhost:55432/babbledeck_dev} tsx scripts/seed.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@prisma/client": "6",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@types/node": "^26.1.0",
    "prettier": "latest",
    "prisma": "6",
    "tsx": "latest",
    "turbo": "latest",
    "typescript": "5"
  }
}
