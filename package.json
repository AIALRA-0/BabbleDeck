{
  "name": "babbledeck",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "e2e": "env -u NO_COLOR playwright test",
    "e2e:headed": "env -u NO_COLOR playwright test --headed",
    "deploy:production": "scripts/deploy-production.sh",
    "audio:configure:production": "scripts/configure-production-audio-storage.sh",
    "audio:preflight:production": "scripts/preflight-audio-storage-production.sh",
    "audio:cutover:production": "scripts/cutover-audio-storage.sh",
    "livekit:configure:production": "scripts/configure-production-livekit.sh",
    "livekit:preflight:production": "scripts/preflight-livekit-production.sh",
    "livekit:selfhost:install:production": "scripts/install-production-livekit-selfhost.sh",
    "livekit:ui-smoke:production": "scripts/livekit-ui-smoke-production.sh",
    "backup:verify:production": "scripts/verify-latest-backup-production.sh",
    "backup:verify:install:production": "scripts/install-production-backup-verify.sh",
    "health:monitor:production": "scripts/monitor-production-health.sh",
    "health:install:production": "scripts/install-production-health-monitor.sh",
    "metrics:collect:production": "scripts/collect-production-metrics.sh",
    "metrics:install:production": "scripts/install-production-metrics-monitor.sh",
    "load:smoke:production": "scripts/load-smoke-production.sh",
    "soniox:smoke:production": "scripts/soniox-smoke-production.sh",
    "soniox:ui-smoke:production": "scripts/soniox-ui-smoke-production.sh",
    "security:audit:production": "scripts/security-baseline-production.sh",
    "logs:install:production": "scripts/install-production-logrotate.sh",
    "wrappers:check": "tsx scripts/verify-wrapper-configs.ts",
    "db:validate": "DATABASE_URL=${DATABASE_URL:-postgresql://babbledeck:babbledeck@localhost:55432/babbledeck_dev} prisma validate --schema db/schema.prisma",
    "db:generate": "DATABASE_URL=${DATABASE_URL:-postgresql://babbledeck:babbledeck@localhost:55432/babbledeck_dev} prisma generate --schema db/schema.prisma",
    "db:migrate": "DATABASE_URL=${DATABASE_URL:-postgresql://babbledeck:babbledeck@localhost:55432/babbledeck_dev} prisma migrate deploy --schema db/schema.prisma",
    "db:migrate:dev": "DATABASE_URL=${DATABASE_URL:-postgresql://babbledeck:babbledeck@localhost:55432/babbledeck_dev} prisma migrate dev --schema db/schema.prisma",
    "db:seed": "pnpm db:generate && DATABASE_URL=${DATABASE_URL:-postgresql://babbledeck:babbledeck@localhost:55432/babbledeck_dev} tsx scripts/seed.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@prisma/client": "6",
    "livekit-server-sdk": "^2.16.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@types/node": "^26.1.0",
    "prettier": "latest",
    "prisma": "6",
    "tsx": "latest",
    "turbo": "latest",
    "typescript": "5"
  }
}
