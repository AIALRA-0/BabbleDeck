# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ORIGIN=http://localhost:3000

# Auth
AUTH_SECRET=replace-with-random-64-byte-secret
SEED_ADMIN_EMAIL=admin@example.invalid
SEED_ADMIN_PASSWORD=replace-with-secure-password-from-operator-never-commit

# Database
DATABASE_URL=postgresql://babbledeck:babbledeck@localhost:55432/babbledeck_dev

# Audio object storage (self-hosted server default)
AUDIO_STORAGE_DRIVER=local
AUDIO_STORAGE_DIR=./storage/babbledeck
AUDIO_RETENTION_DAYS=30
AUDIO_RETENTION_DRY_RUN=false
AUDIO_STORAGE_BUCKET=
AUDIO_STORAGE_ENDPOINT=
AUDIO_STORAGE_REGION=
AUDIO_STORAGE_ACCESS_KEY_ID=
AUDIO_STORAGE_SECRET_ACCESS_KEY=
AUDIO_STORAGE_FORCE_PATH_STYLE=
SOURCE_AUDIO_STORAGE_DIR=./storage/babbledeck

# Soniox default provider
SONIOX_API_KEY=replace-with-soniox-key
SONIOX_WEBSOCKET_URL=wss://stt-rt.soniox.com/transcribe-websocket
SONIOX_REALTIME_MODEL=stt-rt-v5
SONIOX_DEFAULT_TARGET_LANGUAGE=zh
SONIOX_DEFAULT_SOURCE_MODE=auto

# Optional providers
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
OPENAI_API_KEY=

# LiveKit V2 multi-audio mode
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_TOKEN_TTL_SECONDS=900
LIVEKIT_TOKEN_RATE_LIMIT_PER_MINUTE=60

# Optional Cloudflare R2 / S3-compatible migration target
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Optional when R2_ACCOUNT_ID is set; otherwise use https://ACCOUNT_ID.r2.cloudflarestorage.com.
R2_ENDPOINT=
R2_PUBLIC_BASE_URL=

# Realtime and test mode
REALTIME_TRANSPORT=polling
RECORDER_WS_HOST=127.0.0.1
RECORDER_WS_PORT=11971
NEXT_PUBLIC_RECORDER_WS_URL=
MOCK_PROVIDER_ENABLED=true
E2E_BASE_URL=http://localhost:3100
E2E_ADMIN_EMAIL=admin@example.invalid
E2E_ADMIN_PASSWORD=replace-with-test-password-via-env
E2E_NEW_ADMIN_PASSWORD=replace-with-new-test-password-when-rotation-is-required
E2E_RUN_BUDGET_TEST=false
E2E_RUN_SONIOX_UI_TEST=false
E2E_FAKE_AUDIO_FILE=
E2E_SONIOX_EXPECTED_TEXT=Brooklyn
E2E_SONIOX_EXPECTED_TEXTS=
E2E_SONIOX_SESSION_TITLE=
E2E_SONIOX_RECORD_SECONDS=
BABBLEDECK_SONIOX_UI_SMOKE_EXPECTED_TEXT=Brooklyn
BABBLEDECK_SONIOX_TRACE_EXPECTED_TEXTS=Brooklyn,Spanish,French
BABBLEDECK_SONIOX_TRACE_RECORD_SECONDS=24
BABBLEDECK_SONIOX_TRACE_MIN_USAGE_MS=10000
BABBLEDECK_SONIOX_TRACE_MIN_AUDIO_CHUNKS=5

# Cost controls
DEFAULT_SESSION_BUDGET_CAP_USD=1.50
HARD_MAX_AUDIO_HOUR_COST_USD=3.00
PROVIDER_COST_MOCK_AUDIO_HOUR_USD=0
PROVIDER_COST_SONIOX_REALTIME_AUDIO_HOUR_USD=0.35

# Security/rate limit
LOGIN_RATE_LIMIT_PER_MINUTE=5
LOGIN_IP_RATE_LIMIT_PER_MINUTE=25
SESSION_CREATE_RATE_LIMIT_PER_MINUTE=10
EXPORT_RATE_LIMIT_PER_MINUTE=20
AUDIO_CHUNK_UPLOAD_RATE_LIMIT_PER_MINUTE=240
RECORDER_CONTROL_RATE_LIMIT_PER_MINUTE=30
TRANSCRIPT_EVENT_APPEND_RATE_LIMIT_PER_MINUTE=120
